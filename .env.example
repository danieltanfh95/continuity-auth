# continuity-auth — example environment file.
#
# Copy this to `.env` and fill in real values before running in any
# environment that strangers can reach. `.env` is gitignored.

# --- Datalevin storage ----------------------------------------------------
# Password used in the Datalevin client URI (FPL_DTLV_URI). The dev default
# baked into docker-compose.yml is "change-me" — do not run with that.
FPL_DTLV_PASSWORD=change-me

# Full Datalevin client URI. The docker-compose.yml builds this from
# FPL_DTLV_PASSWORD; if you point the server at a different DB, override here.
# FPL_DTLV_URI=dtlv://admin:real-password@datalevin.internal:8898/continuity-auth

# --- Admin HMAC keystore --------------------------------------------------
# Path to the EDN map of {key-id → 32-byte-base64url-secret} that authorises
# the admin CLI / admin endpoints. Empty = admin endpoints respond 403.
FPL_ADMIN_KEYS_PATH=

# --- Host HMAC keys -------------------------------------------------------
# Path to host-integration HMAC keys (link-account flow, v1.1). Empty in
# v0.1.0 since the link-account handler is not yet wired.
FPL_HOST_KEYS_PATH=

# --- Prometheus /metrics scrape token -------------------------------------
# Bearer token required on Authorization: Bearer <token> for /metrics.
# Empty = /metrics returns 401 (refuses to ship open by default).
FPL_PROMETHEUS_BEARER=

# --- OTel exporter --------------------------------------------------------
# OTLP endpoint for tracing (empty = no tracing exported).
FPL_OTEL_ENDPOINT=

# --- HTTP server ----------------------------------------------------------
# Defaults are sensible for `docker compose up`. Override if you need to bind
# to a non-standard interface or port.
# FPL_HTTP_HOST=0.0.0.0
# FPL_HTTP_PORT=8080
