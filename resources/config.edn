;; Aero-driven runtime configuration.
;;
;; Resolution order: this file is read by aero/read-config with the current
;; :profile (:dev, :test, :prod). Values can be overridden by env vars using
;; the #env reader tag, with a default fallback in #or.
{:continuity-auth/version "0.1.0"

 :server
 {:host        #or [#env CONTINUITY_AUTH_HTTP_HOST "0.0.0.0"]
  :port        #long #or [#env CONTINUITY_AUTH_HTTP_PORT "8080"]
  :join?       false
  :max-threads #long #or [#env CONTINUITY_AUTH_HTTP_THREADS "64"]
  :send-server-version? false}

 :datalevin
 {:uri         #or [#env CONTINUITY_AUTH_DTLV_URI
                    #profile {:dev  "/tmp/continuity-auth-dev.dtlv"
                              :test :inmem
                              :prod nil}]
  :db-name     #or [#env CONTINUITY_AUTH_DTLV_DB_NAME "continuity-auth"]
  :write-mode  #keyword #or [#env CONTINUITY_AUTH_DTLV_WRITE_MODE "async"]}  ; :async | :sync

 :replay
 {:timestamp-tolerance-seconds  60
  :nonce-ttl-seconds            120
  :sweeper-interval-seconds     30}

 :ratelimit
 {:windows  [{:window :1m   :seconds 60}
             {:window :5m   :seconds 300}
             {:window :1d   :seconds 86400}]
  ;; Per-caller token bucket per (tier, window). A cell is either a bare
  ;; capacity (leak rate derived as capacity/window-seconds) or a map
  ;; {:capacity N :leak-per-sec R} to set burst size and steady drain
  ;; independently. Both forms may be mixed freely.
  :tiers
  {:anonymous  {:1m 1   :5m 5    :1d 100}
   :tracked    {:1m 30  :5m 120  :1d 5000}
   :penalized  {:1m 0   :5m 1    :1d 20}     ; 1 req per 5 minutes
   :banned     {:1m 0   :5m 0    :1d 1}}     ; 1 req per hour ≈ 24/day; tightened to 1

  ;; Per-tier scheduling weight surfaced as :priority_weight in the verify
  ;; response (advisory host-side input for weighted fair queuing; not
  ;; enforced here). Defaults mirror the :1m capacity ratio.
  :priority-weights
  {:anonymous 1.0  :tracked 30.0  :penalized 0.0  :banned 0.0}

  ;; OPTIONAL class-level back-pressure: a SHARED token bucket per
  ;; (tier, window) that every caller of that tier draws from collectively,
  ;; orthogonal to the per-caller buckets above. Bounds aggregate tier
  ;; throughput so a flood of many distinct identities — each within its
  ;; own per-caller budget — cannot collectively swamp the service. Same
  ;; bare-or-map cell shape as :tiers. Empty ⇒ feature off (no class cap).
  ;; Size each cap to your instance's headroom: capacity is per-window
  ;; across ALL callers of the tier, so :1m N means "≤ N anonymous
  ;; requests cluster-wide per minute." Only the windows you list are
  ;; capped. Example (commented; tune to capacity then enable):
  ;;   :class-caps {:anonymous {:1m 6000 :1d 2000000}
  ;;                :penalized {:1m 200}}
  :class-caps {}}

 ;; Per-IP exponential-backoff on /v1/bootstrap. See plan §"Time as a
 ;; resource" and docs/threat-model.md T14. Each allow sets up the next
 ;; penalty (floor × factor^consecutive × suspicion, capped at cap);
 ;; a quiet period greater than reset-threshold resets the strike count.
 :bootstrap-rate-limit
 {:floor-ms              #long #or [#env CONTINUITY_AUTH_BOOT_FLOOR_MS  "1000"]    ; 1s
  :cap-ms                #long #or [#env CONTINUITY_AUTH_BOOT_CAP_MS    "60000"]   ; 60s
  :doubling-factor       #long #or [#env CONTINUITY_AUTH_BOOT_FACTOR    "2"]
  :reset-threshold-ms    #long #or [#env CONTINUITY_AUTH_BOOT_RESET_MS  "300000"]  ; 5m

  ;; Tier 2 — IP-anchored signals. Cached aggressively per-IP; on read
  ;; failure / timeout the multiplier degrades to neutral (no penalty
  ;; inflation) and a `cauth_bootstrap_signal_fallback_total` metric ticks.
  :signals-enabled?      #boolean #or [#env CONTINUITY_AUTH_BOOT_SIGNALS "true"]
  :signal-read-timeout-ms #long #or [#env CONTINUITY_AUTH_BOOT_SIG_TIMEOUT "50"]
  :signal-cache-ttl-ms    #long #or [#env CONTINUITY_AUTH_BOOT_SIG_TTL   "300000"]  ; 5m

  ;; Tier 3 — operator-supplied datacenter / cloud-provider CIDR list.
  ;; Empty by default; in production set to a comma-separated list of
  ;; CIDRs from your cloud providers' published ranges (Hetzner, AWS,
  ;; OVH, DigitalOcean — see docs/runbook.md §"Datacenter CIDR refresh").
  ;; IPs in this list get ×5 on the suspicion multiplier.
  :datacenter-cidrs      #or [#env CONTINUITY_AUTH_BOOT_DC_CIDRS ""]}

 ;; Spaced-continuity trust weighting. Trust is NOT a running sum of
 ;; per-verify deltas; it is a memory weight recomputed at read time from a
 ;; small per-identity sketch (clean-count, spacing, span, decay, violation
 ;; rate). Spaced recurrence (a key seen long ago and again recently) is
 ;; worth more than massed recurrence (frequent, clustered), which makes
 ;; earned trust expensive to farm. See
 ;; `.plans/spaced-continuity-trust-model.md` (§Calibration) and
 ;; `continuity-auth.server.identity.score`.
 ;;
 ;;   freq   = min(√clean-count, freq-cap)
 ;;   span   = (1 + ln(1 + span-days))^span-exponent
 ;;   gap    = 1 + spacing                         ; spacing = Σ ln(1+gap_days)
 ;;   within = (span-days < span-min-days) ? within-burst-penalty : 1.0
 ;;   decay  = 0.5 ^ (idle-days / decay-half-life-days)
 ;;   base   = freq · span · gap · within · decay
 ;;   earned = 1 − 2^(−base / squash-scale)
 ;;   vrate  = violation-count / (violation-count + clean-count)
 ;;   score  = clamp01( (score-floor + (1−score-floor)·earned)·(1 − violation-k·vrate) )
 :scoring
 {:freq-cap             4.0     ; raw volume saturates fast (anti-farming)
  :span-exponent        1.5     ; calendar-longevity curve
  :within-burst-penalty 0.5     ; halve a single-burst (cram) identity
  :span-min-days        1.0     ; below this span, treat as a burst
  :gap-min-days         0.25    ; 6h: shorter gaps accrue no spacing
  :decay-half-life-days 30.0    ; idle trust halves in a month
  :squash-scale         60.0    ; weight→[0,1] squash scale (W0)
  :score-floor          0.1     ; fresh clean key floor (anonymous band)
  :violation-k          1.0}    ; violation-rate erosion strength

 :trusted-proxies
 {;; Allowlist of trusted upstream CIDRs that we accept :ip-header from.
  ;; Empty means we use the direct connection IP. Configure carefully.
  :cidrs       #or [#env CONTINUITY_AUTH_TRUSTED_PROXY_CIDRS ""]   ; e.g. "10.0.0.0/8,fd00::/8"
  :ip-header   #or [#env CONTINUITY_AUTH_IP_HEADER "x-forwarded-for"]}

 :hmac
 {;; Per-integration HMAC keys. In production these come from a secret
  ;; manager and are loaded by a separate secrets-loader component.
  :host-keys-path  #or [#env CONTINUITY_AUTH_HOST_HMAC_KEYS_PATH ""]
  :admin-keys-path #or [#env CONTINUITY_AUTH_ADMIN_HMAC_KEYS_PATH ""]}

 ;; Server-side IP-HMAC key. The raw client IP is hashed at HTTP ingress
 ;; (`wrap-trusted-proxy-ip`) under this key; only the hash is stored.
 ;; Precedence at startup (see `continuity-auth.server.crypto.ip-hmac`):
 ;;   1. `CONTINUITY_AUTH_IP_HMAC_KEY` (base64, 32 bytes) — direct env-supplied secret
 ;;   2. `:key-path` (or `CONTINUITY_AUTH_IP_HMAC_KEY_PATH`) — EDN keyfile on disk
 ;;   3. If the path has no file: auto-generate 32 SecureRandom bytes,
 ;;      write the EDN file with mode 0600, use it. Subsequent restarts
 ;;      re-read the same file.
 ;; The file MUST persist across restarts; losing it fragments the
 ;; cluster grouping for all existing tuples.
 :ip-hmac
 {:key-path #or [#env CONTINUITY_AUTH_IP_HMAC_KEY_PATH
                 #profile {:dev  "/tmp/continuity-auth-dev-ip-hmac.key"
                           :test "/tmp/continuity-auth-test-ip-hmac.key"
                           :prod "/var/lib/continuity-auth/ip-hmac.key"}]
  :key-b64  #or [#env CONTINUITY_AUTH_IP_HMAC_KEY ""]}

 ;; Server-side knowledge-factor verifier-wrap key (v6, /v1/set-verifier +
 ;; /v1/recover-identity). The KF verifier (an Ed25519 public key derived
 ;; client-side from the user's secret) is encrypted under this key with
 ;; AES-256-GCM before storage, so a DB-only dump cannot mount an offline
 ;; dictionary attack. SEPARATE from the IP-HMAC key (purpose separation).
 ;; Same precedence as :ip-hmac:
 ;;   1. CONTINUITY_AUTH_KF_WRAP_KEY (base64, 32 bytes) — direct env secret
 ;;   2. :key-path (or CONTINUITY_AUTH_KF_WRAP_KEY_PATH) — EDN keyfile
 ;;   3. If the path has no file: auto-generate 32 SecureRandom bytes,
 ;;      write the EDN file with mode 0600, use it.
 ;; The file MUST persist across restarts; losing it makes every stored
 ;; verifier permanently unrecoverable (reclaim breaks; device-key auth is
 ;; unaffected). Back it up alongside the Datalevin store and the IP-HMAC key.
 :kf-wrap
 {:key-path #or [#env CONTINUITY_AUTH_KF_WRAP_KEY_PATH
                 #profile {:dev  "/tmp/continuity-auth-dev-kf-wrap.key"
                           :test "/tmp/continuity-auth-test-kf-wrap.key"
                           :prod "/var/lib/continuity-auth/kf-wrap.key"}]
  :key-b64  #or [#env CONTINUITY_AUTH_KF_WRAP_KEY ""]}

 ;; Biscuit capability-token root SIGNING key (v0.5.0, /v1/issue-token).
 ;; A 32-byte Ed25519 seed; the PUBLIC half is published at
 ;; /v1/token-pubkey for hosts to verify tokens offline. SEPARATE from the
 ;; IP-HMAC and kf-wrap keys (purpose separation). Same precedence as
 ;; :ip-hmac / :kf-wrap:
 ;;   1. CONTINUITY_AUTH_BISCUIT_ROOT_KEY (base64, 32 bytes) — direct env seed
 ;;   2. :key-path (or CONTINUITY_AUTH_BISCUIT_ROOT_KEY_PATH) — EDN keyfile
 ;;   3. If the path has no file: auto-generate 32 SecureRandom bytes (0600).
 ;; The file MUST persist across restarts; rotating it invalidates every
 ;; outstanding token under the old pubkey. Back it up alongside the store.
 ;; `:ttl-ms` is the per-tier cap on token lifetime (lifetime scales with
 ;; earned trust); a tier whose cap is 0 cannot mint. `:max-ttl-ms` is a
 ;; global ceiling above all tiers.
 :biscuit
 {:key-path #or [#env CONTINUITY_AUTH_BISCUIT_ROOT_KEY_PATH
                 #profile {:dev  "/tmp/continuity-auth-dev-biscuit-root.key"
                           :test "/tmp/continuity-auth-test-biscuit-root.key"
                           :prod "/var/lib/continuity-auth/biscuit-root.key"}]
  :key-b64    #or [#env CONTINUITY_AUTH_BISCUIT_ROOT_KEY ""]
  :ttl-ms     {:anonymous 60000 :tracked 300000 :penalized 30000 :banned 0}
  :max-ttl-ms 900000}

 :observability
 {:metrics-enabled?     true
  :prometheus-bearer    #or [#env CONTINUITY_AUTH_PROM_BEARER ""]
  :otel-endpoint        #or [#env CONTINUITY_AUTH_OTEL_ENDPOINT ""]
  :otel-service-name    "continuity-auth"
  :log-level            #keyword #or [#env CONTINUITY_AUTH_LOG_LEVEL "info"]}

 :grace
 {:key-rotation-overlap-seconds  #long #or [#env CONTINUITY_AUTH_KEY_ROT_GRACE_S "86400"]   ; 24h
  :host-link-cooling-off-seconds #long #or [#env CONTINUITY_AUTH_HOST_LINK_COOL_S "86400"]} ; 24h

 :limits
 {:max-fp-signals-bytes  4096
  :max-body-bytes        65536
  :max-key-bytes         128
  :max-signature-bytes   128
  :max-nonce-bytes       64}

 :profiles
 {:dev   {}
  :test  {}
  :prod  {}}}
