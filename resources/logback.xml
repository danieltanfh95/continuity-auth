<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <!-- One-line JSON-friendly layout; mulog emits its own structured events
           separately. This appender only catches incidental SLF4J output. -->
      <pattern>{"ts":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}","level":"%level","logger":"%logger{36}","thread":"%thread","msg":%msg}%n</pattern>
    </encoder>
  </appender>

  <logger name="org.eclipse.jetty"   level="INFO"/>
  <logger name="datalevin"           level="INFO"/>
  <logger name="reitit"              level="INFO"/>
  <logger name="io.netty"            level="WARN"/>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
